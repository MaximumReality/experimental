<script>
const canvas = document.getElementById('game')
const ctx = canvas.getContext('2d')

let lastTime = 0

const player = {
  x: 400,
  y: 300,
  vx: 0,
  vy: 0
}

const keys = new Set()

// keyboard (optional)
window.addEventListener('keydown', e => keys.add(e.key))
window.addEventListener('keyup', e => keys.delete(e.key))

// 🌟 TOUCH CONTROL
let touchActive = false
let touchX = 0
let touchY = 0

canvas.addEventListener('touchstart', (e) => {
  e.preventDefault()
  const t = e.touches[0]
  touchActive = true
  touchX = t.clientX
  touchY = t.clientY
}, { passive: false })

canvas.addEventListener('touchmove', (e) => {
  e.preventDefault()
  const t = e.touches[0]
  touchX = t.clientX
  touchY = t.clientY
}, { passive: false })

canvas.addEventListener('touchend', () => {
  touchActive = false
})

// 🎮 GAME LOGIC
function update(dt) {
  let vx = 0
  let vy = 0

  // keyboard fallback
  if (keys.has('ArrowRight') || keys.has('d')) vx += 1
  if (keys.has('ArrowLeft') || keys.has('a')) vx -= 1
  if (keys.has('ArrowUp') || keys.has('w')) vy -= 1
  if (keys.has('ArrowDown') || keys.has('s')) vy += 1

  // TOUCH = move toward finger
  if (touchActive) {
    const rect = canvas.getBoundingClientRect()
    const tx = (touchX - rect.left) * (canvas.width / rect.width)
    const ty = (touchY - rect.top) * (canvas.height / rect.height)

    vx = tx - player.x
    vy = ty - player.y

    const dist = Math.hypot(vx, vy)
    if (dist > 5) {
      vx /= dist
      vy /= dist
    } else {
      vx = 0
      vy = 0
    }
  }

  player.vx = vx * 200
  player.vy = vy * 200

  player.x += player.vx * dt
  player.y += player.vy * dt
}

// 🎨 DRAW
function draw(t) {
  ctx.clearRect(0, 0, canvas.width, canvas.height)

  ctx.fillStyle = '#8b00ff'
  ctx.beginPath()
  ctx.arc(player.x, player.y, 10, 0, Math.PI * 2)
  ctx.fill()

  ctx.fillStyle = `rgba(191,0,255,${0.6 + Math.sin(t * 0.003) * 0.4})`
  ctx.font = '14px Courier New'
  const text = '[ TOUCH ANYWHERE TO MOVE ]'
  ctx.fillText(text, 400 - ctx.measureText(text).width / 2, 350)
}

// 🔁 LOOP
function loop(time) {
  const dt = (time - lastTime) / 1000
  lastTime = time

  update(dt)
  draw(time)

  requestAnimationFrame(loop)
}

requestAnimationFrame(loop)

function startGame() {
  const overlay = document.getElementById('overlay')
  if (overlay) overlay.style.display = 'none'
}

// works on phone
canvas.addEventListener('touchstart', startGame)

// works on desktop
canvas.addEventListener('click', startGame)
</script>
